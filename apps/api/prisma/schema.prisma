// Prisma Schema for Vully Apartment Management Platform
// Database: PostgreSQL 15+ with pgvector extension

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, uuidOssp(map: "uuid-ossp")]
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  admin
  technician
  resident
}

enum ApartmentStatus {
  vacant
  occupied
  maintenance
  reserved
}

enum ContractStatus {
  draft
  active
  expired
  terminated
}

enum InvoiceStatus {
  draft
  pending
  paid
  overdue
  cancelled
}

enum IncidentCategory {
  plumbing
  electrical
  hvac
  structural
  appliance
  pest
  noise
  security
  other
}

enum IncidentStatus {
  open
  assigned
  in_progress
  pending_review
  resolved
  closed
}

enum IncidentPriority {
  low
  medium
  high
  urgent
}

enum BillingJobStatus {
  pending
  processing
  completed
  failed
}

// =============================================================================
// IDENTITY MODULE
// =============================================================================

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(resident)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  phone        String?  @db.VarChar(20)
  profileData  Json     @default("{}") @map("profile_data")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  refreshTokens  RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs      AuditLog[]       @relation("ActorLogs")
  contracts      Contract[]       @relation("TenantContracts")
  createdContracts Contract[]     @relation("ContractCreator")
  meterReadings  MeterReading[]
  reportedIncidents Incident[]    @relation("ReportedIncidents")
  assignedIncidents Incident[]    @relation("AssignedIncidents")
  incidentComments IncidentComment[]
  notifications  Notification[]
  chatQueries    ChatQuery[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(512)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(512)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  action       String   @db.VarChar(50)
  resourceType String   @map("resource_type") @db.VarChar(100)
  resourceId   String?  @map("resource_id") @db.Uuid
  oldValues    Json?    @map("old_values")
  newValues    Json?    @map("new_values")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  actor User? @relation("ActorLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([resourceType, resourceId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// APARTMENTS MODULE
// =============================================================================

model Building {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(255)
  address    String   @db.Text
  city       String   @db.VarChar(100)
  floorCount Int      @map("floor_count")
  svgMapData String?  @map("svg_map_data") @db.Text
  amenities  Json     @default("[]")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  apartments   Apartment[]
  utilityTiers UtilityTier[]

  @@map("buildings")
}

model Apartment {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buildingId    String          @map("building_id") @db.Uuid
  unitNumber    String          @map("unit_number") @db.VarChar(20)
  floor         Int
  status        ApartmentStatus @default(vacant)
  areaSqm       Decimal?        @map("area_sqm") @db.Decimal(10, 2)
  bedroomCount  Int             @default(1) @map("bedroom_count")
  bathroomCount Int             @default(1) @map("bathroom_count")
  features      Json            @default("{}")
  svgElementId  String?         @map("svg_element_id") @db.Text
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  building      Building       @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  contracts     Contract[]
  meterReadings MeterReading[]
  incidents     Incident[]

  @@unique([buildingId, unitNumber])
  @@index([buildingId])
  @@index([status])
  @@map("apartments")
}

model Contract {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apartmentId   String         @map("apartment_id") @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  status        ContractStatus @default(active)
  startDate     DateTime       @map("start_date") @db.Date
  endDate       DateTime?      @map("end_date") @db.Date
  rentAmount    Decimal        @map("rent_amount") @db.Decimal(12, 2)
  depositMonths Int            @default(2) @map("deposit_months")
  depositAmount Decimal?       @map("deposit_amount") @db.Decimal(12, 2)
  termsNotes    String?        @map("terms_notes") @db.Text
  createdById   String?        @map("created_by") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  tenant    User      @relation("TenantContracts", fields: [tenantId], references: [id])
  createdBy User?     @relation("ContractCreator", fields: [createdById], references: [id], onDelete: SetNull)
  invoices  Invoice[]

  @@index([apartmentId])
  @@index([tenantId])
  @@index([status])
  @@map("contracts")
}

// =============================================================================
// BILLING MODULE (with Tiered Pricing - Bậc Thang)
// =============================================================================

model UtilityType {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code     String  @unique @db.VarChar(50)
  name     String  @db.VarChar(100)
  unit     String  @db.VarChar(20)
  isActive Boolean @default(true) @map("is_active")

  // Relations
  tiers         UtilityTier[]
  meterReadings MeterReading[]
  lineItems     InvoiceLineItem[]

  @@map("utility_types")
}

model UtilityTier {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  utilityTypeId String    @map("utility_type_id") @db.Uuid
  buildingId    String?   @map("building_id") @db.Uuid
  tierNumber    Int       @map("tier_number")
  minUsage      Decimal   @map("min_usage") @db.Decimal(12, 2)
  maxUsage      Decimal?  @map("max_usage") @db.Decimal(12, 2)
  unitPrice     Decimal   @map("unit_price") @db.Decimal(12, 4)
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date

  // Relations
  utilityType UtilityType @relation(fields: [utilityTypeId], references: [id], onDelete: Cascade)
  building    Building?   @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([utilityTypeId, effectiveFrom, effectiveTo])
  @@index([buildingId])
  @@map("utility_tiers")
}

model MeterReading {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apartmentId   String   @map("apartment_id") @db.Uuid
  utilityTypeId String   @map("utility_type_id") @db.Uuid
  currentValue  Decimal  @map("current_value") @db.Decimal(12, 2)
  previousValue Decimal? @map("previous_value") @db.Decimal(12, 2)
  billingPeriod String   @map("billing_period") @db.VarChar(7)
  readingDate   DateTime @map("reading_date") @db.Date
  recordedById  String?  @map("recorded_by") @db.Uuid
  imageProofUrl String?  @map("image_proof_url") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  apartment   Apartment   @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  utilityType UtilityType @relation(fields: [utilityTypeId], references: [id])
  recordedBy  User?       @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  lineItems   InvoiceLineItem[]

  @@unique([apartmentId, utilityTypeId, billingPeriod])
  @@index([apartmentId, billingPeriod])
  @@map("meter_readings")
}

model Invoice {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId    String        @map("contract_id") @db.Uuid
  invoiceNumber String        @unique @map("invoice_number") @db.VarChar(50)
  billingPeriod String        @map("billing_period") @db.VarChar(7)
  issueDate     DateTime      @map("issue_date") @db.Date
  dueDate       DateTime      @map("due_date") @db.Date
  status        InvoiceStatus @default(pending)
  subtotal      Decimal       @db.Decimal(12, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paidAt        DateTime?     @map("paid_at") @db.Timestamptz
  notes         String?       @db.Text
  priceSnapshot Json?         @map("price_snapshot")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  contract  Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  lineItems InvoiceLineItem[]

  @@index([contractId])
  @@index([billingPeriod])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceLineItem {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId      String  @map("invoice_id") @db.Uuid
  description    String  @db.VarChar(255)
  quantity       Decimal @db.Decimal(12, 2)
  unitPrice      Decimal @map("unit_price") @db.Decimal(12, 4)
  amount         Decimal @db.Decimal(12, 2)
  utilityTypeId  String? @map("utility_type_id") @db.Uuid
  meterReadingId String? @map("meter_reading_id") @db.Uuid
  tierBreakdown  Json?   @map("tier_breakdown")

  // Relations
  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  utilityType  UtilityType?  @relation(fields: [utilityTypeId], references: [id])
  meterReading MeterReading? @relation(fields: [meterReadingId], references: [id])

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model BillingJob {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobType        String           @map("job_type") @db.VarChar(50)
  billingPeriod  String           @map("billing_period") @db.VarChar(7)
  status         BillingJobStatus @default(pending)
  totalContracts Int              @default(0) @map("total_contracts")
  processedCount Int              @default(0) @map("processed_count")
  failedCount    Int              @default(0) @map("failed_count")
  errorLog       Json?            @map("error_log")
  startedAt      DateTime?        @map("started_at") @db.Timestamptz
  completedAt    DateTime?        @map("completed_at") @db.Timestamptz
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz

  @@index([billingPeriod])
  @@index([status])
  @@map("billing_jobs")
}

// =============================================================================
// INCIDENTS MODULE
// =============================================================================

model Incident {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apartmentId     String           @map("apartment_id") @db.Uuid
  reportedById    String           @map("reported_by") @db.Uuid
  assignedToId    String?          @map("assigned_to") @db.Uuid
  category        IncidentCategory
  priority        IncidentPriority @default(medium)
  status          IncidentStatus   @default(open)
  title           String           @db.VarChar(255)
  description     String           @db.Text
  imageUrls       Json             @default("[]") @map("image_urls")
  resolvedAt      DateTime?        @map("resolved_at") @db.Timestamptz
  resolutionNotes String?          @map("resolution_notes") @db.Text
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  apartment  Apartment         @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  reportedBy User              @relation("ReportedIncidents", fields: [reportedById], references: [id])
  assignedTo User?             @relation("AssignedIncidents", fields: [assignedToId], references: [id], onDelete: SetNull)
  comments   IncidentComment[]

  @@index([apartmentId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([createdAt])
  @@map("incidents")
}

model IncidentComment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  incidentId String   @map("incident_id") @db.Uuid
  authorId   String   @map("author_id") @db.Uuid
  content    String   @db.Text
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@index([incidentId])
  @@map("incident_comments")
}

// =============================================================================
// NOTIFICATIONS MODULE
// =============================================================================

model Notification {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  type         String   @db.VarChar(50)
  title        String   @db.VarChar(255)
  message      String   @db.Text
  resourceType String?  @map("resource_type") @db.VarChar(50)
  resourceId   String?  @map("resource_id") @db.Uuid
  isRead       Boolean  @default(false) @map("is_read")
  readAt       DateTime? @map("read_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================================
// AI MODULE (Vector Storage for RAG)
// =============================================================================

model Document {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String   @db.VarChar(255)
  content   String   @db.Text
  category  String   @db.VarChar(100)
  metadata  Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  chunks DocumentChunk[]

  @@index([category])
  @@index([isActive])
  @@map("documents")
}

model DocumentChunk {
  id         String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String                         @map("document_id") @db.Uuid
  content    String                         @db.Text
  embedding  Unsupported("vector(768)")?    // Gemini embedding dimension is 768
  chunkIndex Int                            @map("chunk_index")
  metadata   Json                           @default("{}")
  createdAt  DateTime                       @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

model ChatQuery {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  query       String   @db.Text
  response    String   @db.Text
  sourceDocs  Json     @default("[]") @map("source_docs") // Document IDs used
  tokensUsed  Int      @default(0) @map("tokens_used")
  responseTime Int     @default(0) @map("response_time") // milliseconds
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_queries")
}
