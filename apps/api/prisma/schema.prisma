generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp"), vector]
}

model apartments {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  building_id            String          @db.Uuid
  unit_number            String          @db.VarChar(20)
  floor_index            Int
  status                 ApartmentStatus @default(vacant)
  gross_area             Decimal?        @db.Decimal(10, 2)
  bedroom_count          Int             @default(1)
  bathroom_count         Int             @default(1)
  features               Json            @default("{}")
  svg_element_id         String?
  created_at             DateTime        @default(now()) @db.Timestamptz(6)
  updated_at             DateTime        @db.Timestamptz(6)
  apartment_code         String?         @unique @db.VarChar(30)
  floor_label            String?         @db.VarChar(10)
  unit_type              UnitType?
  net_area               Decimal?        @db.Decimal(10, 2)
  ceiling_height         Decimal?        @db.Decimal(4, 2)
  svg_path_data          String?
  centroid_x             Decimal?        @db.Decimal(10, 4)
  centroid_y             Decimal?        @db.Decimal(10, 4)
  orientation            Orientation?
  balcony_direction      Orientation?
  is_corner_unit         Boolean         @default(false)
  owner_id               String?         @db.Uuid
  ownership_type         OwnershipType?
  pink_book_id           String?         @db.VarChar(50)
  handover_date          DateTime?       @db.Date
  warranty_expiry_date   DateTime?       @db.Date
  is_rented              Boolean         @default(false)
  vat_rate               Decimal?        @db.Decimal(5, 2)
  max_residents          Int?
  current_resident_count Int             @default(0)
  pet_allowed            Boolean?
  pet_limit              Int?
  access_card_limit      Int?
  intercom_code          String?         @db.VarChar(20)
  electric_meter_id      String?         @db.VarChar(50)
  water_meter_id         String?         @db.VarChar(50)
  gas_meter_id           String?         @db.VarChar(50)
  power_capacity         Int?
  ac_unit_count          Int?
  fire_detector_id       String?         @db.VarChar(50)
  sprinkler_count        Int?
  internet_terminal_loc  String?         @db.VarChar(255)
  assigned_car_slot      String?         @db.VarChar(30)
  assigned_moto_slot     String?         @db.VarChar(30)
  mailbox_number         String?         @db.VarChar(20)
  storage_unit_id        String?         @db.VarChar(30)
  mgmt_fee_config_id     String?         @db.Uuid
  billing_start_date     DateTime?       @db.Date
  billing_cycle          BillingCycle    @default(monthly)
  bank_account_virtual   String?         @db.VarChar(30)
  late_fee_waived        Boolean         @default(false)
  parent_unit_id         String?         @db.Uuid
  is_merged              Boolean         @default(false)
  sync_status            SyncStatus      @default(disconnected)
  portal_access_enabled  Boolean         @default(true)
  technical_drawing_url  String?
  notes_admin            String?

  // Policy Override Fields (null = inherit from building policy)
  max_residents_override     Int?
  access_card_limit_override Int?
  pet_allowed_override       Boolean?
  pet_limit_override         Int?
  billing_cycle_override     BillingCycle?

  // Relations
  buildings              buildings               @relation(fields: [building_id], references: [id], onDelete: Cascade)
  management_fee_configs management_fee_configs? @relation(fields: [mgmt_fee_config_id], references: [id])
  users                  users?                  @relation(fields: [owner_id], references: [id])
  apartments             apartments?             @relation("apartmentsToapartments", fields: [parent_unit_id], references: [id])
  other_apartments       apartments[]            @relation("apartmentsToapartments")
  contracts              contracts[]
  incidents              incidents[]
  meter_readings         meter_readings[]
  parking_slots          parking_slots[]

  @@unique([building_id, unit_number])
  @@index([building_id])
  @@index([floor_index])
  @@index([is_merged])
  @@index([owner_id])
  @@index([status])
  @@index([unit_type])
}

model audit_logs {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id      String?  @db.Uuid
  action        String   @db.VarChar(50)
  resource_type String   @db.VarChar(100)
  resource_id   String?  @db.Uuid
  old_values    Json?
  new_values    Json?
  ip_address    String?  @db.VarChar(45)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  users         users?   @relation(fields: [actor_id], references: [id])

  @@index([actor_id])
  @@index([created_at])
  @@index([resource_type, resource_id])
}

model billing_jobs {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_type        String           @db.VarChar(50)
  billing_period  String           @db.VarChar(7)
  status          BillingJobStatus @default(pending)
  total_contracts Int              @default(0)
  processed_count Int              @default(0)
  failed_count    Int              @default(0)
  error_log       Json?
  started_at      DateTime?        @db.Timestamptz(6)
  completed_at    DateTime?        @db.Timestamptz(6)
  created_at      DateTime         @default(now()) @db.Timestamptz(6)

  @@index([billing_period])
  @@index([status])
}

model buildings {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String                   @db.VarChar(255)
  address                String
  city                   String                   @db.VarChar(100)
  floor_count            Int
  svg_map_data           String?
  amenities              Json                     @default("[]")
  is_active              Boolean                  @default(true)
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @db.Timestamptz(6)
  floor_heights          Json?
  apartments             apartments[]
  management_fee_configs management_fee_configs[]
  utility_tiers          utility_tiers[]
  building_policies      building_policies[]
  parking_zones          parking_zones[]
}

// ============================================================================
// Building Policies (Versioned)
// ============================================================================

model building_policies {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  building_id String @db.Uuid

  // Occupancy Rules
  default_max_residents     Int? // null = calculated by area formula (25m² per person)
  access_card_limit_default Int     @default(4)
  pet_allowed               Boolean @default(false)
  pet_limit_default         Int     @default(0)

  // Billing Configuration
  default_billing_cycle BillingCycle @default(monthly)
  late_fee_rate_percent Decimal?     @db.Decimal(5, 2) // e.g., 5.00 for 5%
  late_fee_grace_days   Int          @default(7)

  // Trash Collection
  trash_collection_days String[] // ['monday', 'thursday']
  trash_collection_time String?  @db.VarChar(20) // e.g., "07:00-09:00"
  trash_fee_per_month   Decimal? @db.Decimal(12, 2)

  // Versioning
  effective_from DateTime  @db.Date
  effective_to   DateTime? @db.Date // null = current policy
  created_by     String?   @db.Uuid
  created_at     DateTime  @default(now()) @db.Timestamptz(6)

  // Relations
  buildings buildings @relation(fields: [building_id], references: [id], onDelete: Cascade)
  users     users?    @relation(fields: [created_by], references: [id])

  @@index([building_id, effective_from])
  @@index([building_id, effective_to])
}

// ============================================================================
// Parking Management
// ============================================================================

model parking_zones {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  building_id   String      @db.Uuid
  name          String      @db.VarChar(50) // e.g., "Basement 1 - Zone A"
  code          String      @db.VarChar(10) // e.g., "B1-A"
  slot_type     ParkingType // car | motorcycle | bicycle
  total_slots   Int
  fee_per_month Decimal?    @db.Decimal(12, 2)
  is_active     Boolean     @default(true)
  created_at    DateTime    @default(now()) @db.Timestamptz(6)

  // Relations
  buildings     buildings       @relation(fields: [building_id], references: [id], onDelete: Cascade)
  parking_slots parking_slots[]

  @@unique([building_id, code])
  @@index([building_id])
}

model parking_slots {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  zone_id         String            @db.Uuid
  slot_number     String            @db.VarChar(10) // e.g., "023"
  full_code       String            @db.VarChar(20) // e.g., "B1-A-023" (computed)
  assigned_apt_id String?           @db.Uuid
  assigned_at     DateTime?         @db.Timestamptz(6)
  fee_override    Decimal?          @db.Decimal(12, 2) // null = use zone default
  status          ParkingSlotStatus @default(available)
  notes           String?
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @db.Timestamptz(6)

  // Relations
  parking_zones parking_zones @relation(fields: [zone_id], references: [id], onDelete: Cascade)
  apartments    apartments?   @relation(fields: [assigned_apt_id], references: [id])

  @@unique([zone_id, slot_number])
  @@index([assigned_apt_id])
  @@index([status])
}

model chat_queries {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  query         String
  response      String
  source_docs   Json     @default("[]")
  tokens_used   Int      @default(0)
  response_time Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
}

model contracts {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apartment_id        String         @db.Uuid
  tenant_id           String         @db.Uuid
  status              ContractStatus @default(active)
  start_date          DateTime       @db.Date
  end_date            DateTime?      @db.Date
  rent_amount         Decimal        @db.Decimal(12, 2)
  deposit_months      Int            @default(2)
  deposit_amount      Decimal?       @db.Decimal(12, 2)
  citizen_id          String?        @db.VarChar(30)
  number_of_residents Int?
  terms_notes         String?
  created_by          String?        @db.Uuid
  created_at          DateTime       @default(now()) @db.Timestamptz(6)
  updated_at          DateTime       @db.Timestamptz(6)

  // Payment tracking fields (new)
  contract_type         ContractType @default(rental)
  purchase_price        Decimal?     @db.Decimal(15, 2)
  down_payment          Decimal?     @db.Decimal(15, 2)
  transfer_date         DateTime?    @db.Date
  option_fee            Decimal?     @db.Decimal(15, 2)
  purchase_option_price Decimal?     @db.Decimal(15, 2)
  option_period_months  Int?
  rent_credit_percent   Decimal?     @db.Decimal(5, 2)
  payment_due_day       Int? // Day of month (1-28)

  // Relations
  apartments                        apartments                   @relation(fields: [apartment_id], references: [id], onDelete: Cascade)
  users_contracts_created_byTousers users?                       @relation("contracts_created_byTousers", fields: [created_by], references: [id])
  users_contracts_tenant_idTousers  users                        @relation("contracts_tenant_idTousers", fields: [tenant_id], references: [id])
  invoices                          invoices[]
  payment_schedules                 contract_payment_schedules[]

  @@index([apartment_id])
  @@index([status])
  @@index([tenant_id])
}

model document_chunks {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_id String                 @db.Uuid
  content     String
  embedding   Unsupported("vector")?
  chunk_index Int
  metadata    Json                   @default("{}")
  created_at  DateTime               @default(now()) @db.Timestamptz(6)
  documents   documents              @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id])
}

model documents {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String            @db.VarChar(255)
  content         String
  category        String            @db.VarChar(100)
  metadata        Json              @default("{}")
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @db.Timestamptz(6)
  document_chunks document_chunks[]

  @@index([category])
  @@index([is_active])
}

model incident_comments {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  incident_id String    @db.Uuid
  author_id   String    @db.Uuid
  content     String
  is_internal Boolean   @default(false)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  users       users     @relation(fields: [author_id], references: [id])
  incidents   incidents @relation(fields: [incident_id], references: [id], onDelete: Cascade)

  @@index([incident_id])
}

model incidents {
  id                                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apartment_id                       String              @db.Uuid
  reported_by                        String              @db.Uuid
  assigned_to                        String?             @db.Uuid
  category                           IncidentCategory
  priority                           IncidentPriority    @default(medium)
  status                             IncidentStatus      @default(open)
  title                              String              @db.VarChar(255)
  description                        String
  image_urls                         Json                @default("[]")
  resolved_at                        DateTime?           @db.Timestamptz(6)
  resolution_notes                   String?
  created_at                         DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                         DateTime            @db.Timestamptz(6)
  incident_comments                  incident_comments[]
  apartments                         apartments          @relation(fields: [apartment_id], references: [id], onDelete: Cascade)
  users_incidents_assigned_toTousers users?              @relation("incidents_assigned_toTousers", fields: [assigned_to], references: [id])
  users_incidents_reported_byTousers users               @relation("incidents_reported_byTousers", fields: [reported_by], references: [id])

  @@index([apartment_id])
  @@index([assigned_to])
  @@index([created_at])
  @@index([priority])
  @@index([status])
}

model invoice_line_items {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id       String          @db.Uuid
  description      String          @db.VarChar(255)
  quantity         Decimal         @db.Decimal(12, 2)
  unit_price       Decimal         @db.Decimal(12, 4)
  amount           Decimal         @db.Decimal(12, 2)
  utility_type_id  String?         @db.Uuid
  meter_reading_id String?         @db.Uuid
  tier_breakdown   Json?
  invoices         invoices        @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  meter_readings   meter_readings? @relation(fields: [meter_reading_id], references: [id])
  utility_types    utility_types?  @relation(fields: [utility_type_id], references: [id])

  @@index([invoice_id])
}

model invoices {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id        String               @db.Uuid
  invoice_number     String               @unique @db.VarChar(50)
  billing_period     String               @db.VarChar(7)
  issue_date         DateTime             @db.Date
  due_date           DateTime             @db.Date
  status             InvoiceStatus        @default(pending)
  subtotal           Decimal              @db.Decimal(12, 2)
  tax_amount         Decimal              @default(0) @db.Decimal(12, 2)
  total_amount       Decimal              @db.Decimal(12, 2)
  paid_amount        Decimal              @default(0) @db.Decimal(12, 2)
  paid_at            DateTime?            @db.Timestamptz(6)
  notes              String?
  price_snapshot     Json?
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  invoice_line_items invoice_line_items[]
  contracts          contracts            @relation(fields: [contract_id], references: [id], onDelete: Cascade)

  @@index([billing_period])
  @@index([contract_id])
  @@index([due_date])
  @@index([status])
}

model management_fee_configs {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  building_id    String       @db.Uuid
  unit_type      UnitType?
  price_per_sqm  Decimal      @db.Decimal(12, 2)
  effective_from DateTime     @db.Date
  effective_to   DateTime?    @db.Date
  created_at     DateTime     @default(now()) @db.Timestamptz(6)
  apartments     apartments[]
  buildings      buildings    @relation(fields: [building_id], references: [id], onDelete: Cascade)

  @@index([building_id, effective_from])
}

model meter_readings {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apartment_id       String               @db.Uuid
  utility_type_id    String               @db.Uuid
  current_value      Decimal              @db.Decimal(12, 2)
  previous_value     Decimal?             @db.Decimal(12, 2)
  billing_period     String               @db.VarChar(7)
  reading_date       DateTime             @db.Date
  recorded_by        String?              @db.Uuid
  image_proof_url    String?
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  invoice_line_items invoice_line_items[]
  apartments         apartments           @relation(fields: [apartment_id], references: [id], onDelete: Cascade)
  users              users?               @relation(fields: [recorded_by], references: [id])
  utility_types      utility_types        @relation(fields: [utility_type_id], references: [id])

  @@unique([apartment_id, utility_type_id, billing_period])
  @@index([apartment_id, billing_period])
}

model notifications {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  type          String    @db.VarChar(50)
  title         String    @db.VarChar(255)
  message       String
  resource_type String?   @db.VarChar(50)
  resource_id   String?   @db.Uuid
  is_read       Boolean   @default(false)
  read_at       DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  users         users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([user_id, is_read])
}

model password_reset_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @unique @db.VarChar(512)
  expires_at DateTime @db.Timestamptz(6)
  is_used    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model permissions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key              String             @unique @db.VarChar(100)
  description      String             @db.VarChar(255)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  role_permissions role_permissions[]
}

model refresh_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @unique @db.VarChar(512)
  expires_at DateTime @db.Timestamptz(6)
  ip_address String?  @db.VarChar(45)
  user_agent String?
  is_revoked Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model role_permissions {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role          UserRole
  permission_id String      @db.Uuid
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role, permission_id])
  @@index([permission_id])
  @@index([role])
}

model user_role_assignments {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  role       UserRole
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role])
  @@index([role])
  @@index([user_id])
}

model users {
  id                                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                  String                  @unique @db.VarChar(255)
  password_hash                          String                  @db.VarChar(255)
  role                                   UserRole                @default(resident)
  first_name                             String                  @db.VarChar(100)
  last_name                              String                  @db.VarChar(100)
  phone                                  String?                 @db.VarChar(20)
  profile_data                           Json                    @default("{}")
  is_active                              Boolean                 @default(true)
  created_at                             DateTime                @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime                @db.Timestamptz(6)
  apartments                             apartments[]
  audit_logs                             audit_logs[]
  building_policies                      building_policies[]
  chat_queries                           chat_queries[]
  contracts_contracts_created_byTousers  contracts[]             @relation("contracts_created_byTousers")
  contracts_contracts_tenant_idTousers   contracts[]             @relation("contracts_tenant_idTousers")
  incident_comments                      incident_comments[]
  incidents_incidents_assigned_toTousers incidents[]             @relation("incidents_assigned_toTousers")
  incidents_incidents_reported_byTousers incidents[]             @relation("incidents_reported_byTousers")
  meter_readings                         meter_readings[]
  notifications                          notifications[]
  password_reset_tokens                  password_reset_tokens[]
  refresh_tokens                         refresh_tokens[]
  user_role_assignments                  user_role_assignments[]
  contract_payments                      contract_payments[]
}

model utility_tiers {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  utility_type_id String        @db.Uuid
  building_id     String?       @db.Uuid
  tier_number     Int
  min_usage       Decimal       @db.Decimal(12, 2)
  max_usage       Decimal?      @db.Decimal(12, 2)
  unit_price      Decimal       @db.Decimal(12, 4)
  effective_from  DateTime      @db.Date
  effective_to    DateTime?     @db.Date
  buildings       buildings?    @relation(fields: [building_id], references: [id], onDelete: Cascade)
  utility_types   utility_types @relation(fields: [utility_type_id], references: [id], onDelete: Cascade)

  @@index([building_id])
  @@index([utility_type_id, effective_from, effective_to])
}

model utility_types {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String               @unique @db.VarChar(50)
  name               String               @db.VarChar(100)
  unit               String               @db.VarChar(20)
  is_active          Boolean              @default(true)
  invoice_line_items invoice_line_items[]
  meter_readings     meter_readings[]
  utility_tiers      utility_tiers[]
}

// ============================================================================
// Payment Tracking Models
// ============================================================================

model contract_payment_schedules {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id String @db.Uuid

  // Payment info
  period_label    String      @db.VarChar(100) // "Downpayment", "Rent Apr 2026", "Milestone: Foundation"
  payment_type    PaymentType
  sequence_number Int // Order for display

  // Amounts
  due_date        DateTime @db.Date
  expected_amount Decimal  @db.Decimal(15, 2)
  received_amount Decimal  @default(0) @db.Decimal(15, 2)

  // Status
  status PaymentStatus @default(pending)

  // Metadata
  notes      String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @db.Timestamptz(6)

  // Relations
  contracts contracts           @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  payments  contract_payments[]

  @@index([contract_id, due_date])
  @@index([status])
}

model contract_payments {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schedule_id String @db.Uuid

  // Payment details
  amount           Decimal        @db.Decimal(15, 2)
  payment_date     DateTime       @db.Date
  payment_method   PaymentMethod?
  reference_number String?        @db.VarChar(100) // Bank transfer ref, receipt no.

  // Who recorded it
  recorded_by String   @db.Uuid
  recorded_at DateTime @default(now()) @db.Timestamptz(6)

  // Evidence
  receipt_url String?
  notes       String?

  // Relations
  schedule contract_payment_schedules @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  users    users                      @relation(fields: [recorded_by], references: [id])

  @@index([schedule_id])
  @@index([recorded_by])
}

