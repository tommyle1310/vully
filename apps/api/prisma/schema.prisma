generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp"), vector]
}

model User {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String               @unique @db.VarChar(255)
  passwordHash        String               @map("password_hash") @db.VarChar(255)
  role                UserRole             @default(resident)
  firstName           String               @map("first_name") @db.VarChar(100)
  lastName            String               @map("last_name") @db.VarChar(100)
  phone               String?              @db.VarChar(20)
  profileData         Json                 @default("{}") @map("profile_data")
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  auditLogs           AuditLog[]           @relation("ActorLogs")
  chatQueries         ChatQuery[]
  createdContracts    Contract[]           @relation("ContractCreator")
  contracts           Contract[]           @relation("TenantContracts")
  incidentComments    IncidentComment[]
  assignedIncidents   Incident[]           @relation("AssignedIncidents")
  reportedIncidents   Incident[]           @relation("ReportedIncidents")
  meterReadings       MeterReading[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  roleAssignments     UserRoleAssignment[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(512)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(512)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  action       String   @db.VarChar(50)
  resourceType String   @map("resource_type") @db.VarChar(100)
  resourceId   String?  @map("resource_id") @db.Uuid
  oldValues    Json?    @map("old_values")
  newValues    Json?    @map("new_values")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor        User?    @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([resourceType, resourceId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model UserRoleAssignment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
  @@map("user_role_assignments")
}

model Permission {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key             String           @unique @db.VarChar(100)
  description     String           @db.VarChar(255)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role         UserRole
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@index([permissionId])
  @@map("role_permissions")
}

model Building {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(255)
  address      String
  city         String        @db.VarChar(100)
  floorCount   Int           @map("floor_count")
  svgMapData   String?       @map("svg_map_data")
  amenities    Json          @default("[]")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  floorHeights Json?         @map("floor_heights")
  apartments   Apartment[]
  utilityTiers UtilityTier[]

  @@map("buildings")
}

model Apartment {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buildingId    String          @map("building_id") @db.Uuid
  unitNumber    String          @map("unit_number") @db.VarChar(20)
  floor         Int
  status        ApartmentStatus @default(vacant)
  areaSqm       Decimal?        @map("area_sqm") @db.Decimal(10, 2)
  bedroomCount  Int             @default(1) @map("bedroom_count")
  bathroomCount Int             @default(1) @map("bathroom_count")
  features      Json            @default("{}")
  svgElementId  String?         @map("svg_element_id")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  building      Building        @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  contracts     Contract[]
  incidents     Incident[]
  meterReadings MeterReading[]

  @@unique([buildingId, unitNumber])
  @@index([buildingId])
  @@index([status])
  @@map("apartments")
}

model Contract {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apartmentId   String         @map("apartment_id") @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  status        ContractStatus @default(active)
  startDate     DateTime       @map("start_date") @db.Date
  endDate       DateTime?      @map("end_date") @db.Date
  rentAmount    Decimal        @map("rent_amount") @db.Decimal(12, 2)
  depositMonths Int            @default(2) @map("deposit_months")
  depositAmount Decimal?       @map("deposit_amount") @db.Decimal(12, 2)
  termsNotes    String?        @map("terms_notes")
  createdById   String?        @map("created_by") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  apartment     Apartment      @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("ContractCreator", fields: [createdById], references: [id])
  tenant        User           @relation("TenantContracts", fields: [tenantId], references: [id])
  invoices      Invoice[]

  @@index([apartmentId])
  @@index([tenantId])
  @@index([status])
  @@map("contracts")
}

model UtilityType {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String            @unique @db.VarChar(50)
  name          String            @db.VarChar(100)
  unit          String            @db.VarChar(20)
  isActive      Boolean           @default(true) @map("is_active")
  lineItems     InvoiceLineItem[]
  meterReadings MeterReading[]
  tiers         UtilityTier[]

  @@map("utility_types")
}

model UtilityTier {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  utilityTypeId String      @map("utility_type_id") @db.Uuid
  buildingId    String?     @map("building_id") @db.Uuid
  tierNumber    Int         @map("tier_number")
  minUsage      Decimal     @map("min_usage") @db.Decimal(12, 2)
  maxUsage      Decimal?    @map("max_usage") @db.Decimal(12, 2)
  unitPrice     Decimal     @map("unit_price") @db.Decimal(12, 4)
  effectiveFrom DateTime    @map("effective_from") @db.Date
  effectiveTo   DateTime?   @map("effective_to") @db.Date
  building      Building?   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  utilityType   UtilityType @relation(fields: [utilityTypeId], references: [id], onDelete: Cascade)

  @@index([utilityTypeId, effectiveFrom, effectiveTo])
  @@index([buildingId])
  @@map("utility_tiers")
}

model MeterReading {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apartmentId   String            @map("apartment_id") @db.Uuid
  utilityTypeId String            @map("utility_type_id") @db.Uuid
  currentValue  Decimal           @map("current_value") @db.Decimal(12, 2)
  previousValue Decimal?          @map("previous_value") @db.Decimal(12, 2)
  billingPeriod String            @map("billing_period") @db.VarChar(7)
  readingDate   DateTime          @map("reading_date") @db.Date
  recordedById  String?           @map("recorded_by") @db.Uuid
  imageProofUrl String?           @map("image_proof_url")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  lineItems     InvoiceLineItem[]
  apartment     Apartment         @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  recordedBy    User?             @relation(fields: [recordedById], references: [id])
  utilityType   UtilityType       @relation(fields: [utilityTypeId], references: [id])

  @@unique([apartmentId, utilityTypeId, billingPeriod])
  @@index([apartmentId, billingPeriod])
  @@map("meter_readings")
}

model Invoice {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId    String            @map("contract_id") @db.Uuid
  invoiceNumber String            @unique @map("invoice_number") @db.VarChar(50)
  billingPeriod String            @map("billing_period") @db.VarChar(7)
  issueDate     DateTime          @map("issue_date") @db.Date
  dueDate       DateTime          @map("due_date") @db.Date
  status        InvoiceStatus     @default(pending)
  subtotal      Decimal           @db.Decimal(12, 2)
  taxAmount     Decimal           @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount   Decimal           @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal           @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paidAt        DateTime?         @map("paid_at") @db.Timestamptz(6)
  notes         String?
  priceSnapshot Json?             @map("price_snapshot")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  lineItems     InvoiceLineItem[]
  contract      Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([billingPeriod])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceLineItem {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId      String        @map("invoice_id") @db.Uuid
  description    String        @db.VarChar(255)
  quantity       Decimal       @db.Decimal(12, 2)
  unitPrice      Decimal       @map("unit_price") @db.Decimal(12, 4)
  amount         Decimal       @db.Decimal(12, 2)
  utilityTypeId  String?       @map("utility_type_id") @db.Uuid
  meterReadingId String?       @map("meter_reading_id") @db.Uuid
  tierBreakdown  Json?         @map("tier_breakdown")
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  meterReading   MeterReading? @relation(fields: [meterReadingId], references: [id])
  utilityType    UtilityType?  @relation(fields: [utilityTypeId], references: [id])

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model BillingJob {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobType        String           @map("job_type") @db.VarChar(50)
  billingPeriod  String           @map("billing_period") @db.VarChar(7)
  status         BillingJobStatus @default(pending)
  totalContracts Int              @default(0) @map("total_contracts")
  processedCount Int              @default(0) @map("processed_count")
  failedCount    Int              @default(0) @map("failed_count")
  errorLog       Json?            @map("error_log")
  startedAt      DateTime?        @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime?        @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([billingPeriod])
  @@index([status])
  @@map("billing_jobs")
}

model Incident {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apartmentId     String            @map("apartment_id") @db.Uuid
  reportedById    String            @map("reported_by") @db.Uuid
  assignedToId    String?           @map("assigned_to") @db.Uuid
  category        IncidentCategory
  priority        IncidentPriority  @default(medium)
  status          IncidentStatus    @default(open)
  title           String            @db.VarChar(255)
  description     String
  imageUrls       Json              @default("[]") @map("image_urls")
  resolvedAt      DateTime?         @map("resolved_at") @db.Timestamptz(6)
  resolutionNotes String?           @map("resolution_notes")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  comments        IncidentComment[]
  apartment       Apartment         @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  assignedTo      User?             @relation("AssignedIncidents", fields: [assignedToId], references: [id])
  reportedBy      User              @relation("ReportedIncidents", fields: [reportedById], references: [id])

  @@index([apartmentId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([createdAt])
  @@map("incidents")
}

model IncidentComment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  incidentId String   @map("incident_id") @db.Uuid
  authorId   String   @map("author_id") @db.Uuid
  content    String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  author     User     @relation(fields: [authorId], references: [id])
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_comments")
}

model Notification {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  type         String    @db.VarChar(50)
  title        String    @db.VarChar(255)
  message      String
  resourceType String?   @map("resource_type") @db.VarChar(50)
  resourceId   String?   @map("resource_id") @db.Uuid
  isRead       Boolean   @default(false) @map("is_read")
  readAt       DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Document {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String          @db.VarChar(255)
  content   String
  category  String          @db.VarChar(100)
  metadata  Json            @default("{}")
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  chunks    DocumentChunk[]

  @@index([category])
  @@index([isActive])
  @@map("documents")
}

model DocumentChunk {
  id         String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String                 @map("document_id") @db.Uuid
  content    String
  embedding  Unsupported("vector")?
  chunkIndex Int                    @map("chunk_index")
  metadata   Json                   @default("{}")
  createdAt  DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  document   Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

model ChatQuery {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  query        String
  response     String
  sourceDocs   Json     @default("[]") @map("source_docs")
  tokensUsed   Int      @default(0) @map("tokens_used")
  responseTime Int      @default(0) @map("response_time")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_queries")
}

enum UserRole {
  admin
  technician
  resident
}

enum ApartmentStatus {
  vacant
  occupied
  maintenance
  reserved
}

enum ContractStatus {
  draft
  active
  expired
  terminated
}

enum InvoiceStatus {
  draft
  pending
  paid
  overdue
  cancelled
}

enum IncidentCategory {
  plumbing
  electrical
  hvac
  structural
  appliance
  pest
  noise
  security
  other
}

enum IncidentStatus {
  open
  assigned
  in_progress
  pending_review
  resolved
  closed
}

enum IncidentPriority {
  low
  medium
  high
  urgent
}

enum BillingJobStatus {
  pending
  processing
  completed
  failed
}
